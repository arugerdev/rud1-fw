# Enforce LF line endings for files consumed by Linux tooling. Windows
# checkouts won't convert these to CRLF, which matters because the install
# scripts and systemd units break with CRLF line endings.
*.sh              text eol=lf
*.service         text eol=lf
*.conf            text eol=lf
*.yaml            text eol=lf
*.yml             text eol=lf
Makefile          text eol=lf
deploy/rpi/**     text eol=lf
